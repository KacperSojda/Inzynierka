@model SearchByTagsViewModel

@if (Model.MatchingUsers.Any())
{
    var user = Model.MatchingUsers[Model.CurrentIndex];
    <h3>@user.UserName</h3>
    <p>@user.PublicDescription</p>
    <p>Tagi: @string.Join(", ", user.Tags)</p>

    <form asp-action="NextUser" method="post" style="display: inline;">
        <input type="hidden" name="currentIndex" value="@Model.CurrentIndex" />
        <button type="submit" @(Model.CurrentIndex == Model.MatchingUsers.Count - 1 ? "disabled" : "")>Następny →</button>
    </form>
}
else
{
    <p>Brak użytkowników spełniających kryteria.</p>
}