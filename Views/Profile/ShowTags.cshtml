@model List<INZYNIERKA.Models.Tag>

@{
    ViewData["Title"] = "List of Tags";
}

<h2>Lista tagów</h2>


<table class="table table-striped">
    <thead>
        <tr>
            <th>Nazwa</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tag in Model)
        {
            <tr>
                <td>@tag.Name</td>
            </tr>
        }
    </tbody>
</table>