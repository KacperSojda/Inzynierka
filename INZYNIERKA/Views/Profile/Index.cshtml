@model INZYNIERKA.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Profile Home Page";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" />

<div class="container py-5">
    <div class="text-center mb-4">
        <h1>@Model.UserName</h1>
        <p class="lead">@Model.PublicDescription</p>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-md-4 text-center">
            <img src="@Model.Avatar" alt="Avatar" class="img-fluid rounded-circle mb-3" />
        </div>
        <div class="col-md-8">
            <h4>Private Description:</h4>
            <p>@Model.PrivateDescription</p>

            <h5>Your tags:</h5>
            <ul class="list-inline">
                @foreach (var tag in Model.Tags)
                {
                    <li class="list-inline-item badge bg-primary mx-1">@tag</li>
                }
            </ul>
        </div>
    </div>

    <div class="home-menu">
        <a asp-controller="Profile" asp-action="EditProfile" class="home-edit" title="Edit profile" data-bs-toggle="tooltipp"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-controller="Profile" asp-action="SelectTags" class="home-tags" title="Edit tags" data-bs-toggle="tooltipp"><i class="bi bi-tags"></i> Tags</a>
        <a asp-controller="Profile" asp-action="FriendList" class="home-friends" title="Friend list" data-bs-toggle="tooltipp"><i class="bi bi-people-fill"></i> Friends</i></a>
        <a asp-controller="Profile" asp-action="RequestList" class="home-requests" title="Friend requests" data-bs-toggle="tooltipp"><i class="bi bi-person-badge"></i> Requests</a>
        <a asp-controller="Profile" asp-action="EditAvatar" class="home-avatar" title="Edit Avatar" data-bs-toggle="tooltipp"><i class="bi bi-person-badge"></i> Avatar</a>
    </div>
</div>

<style>
    .home-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        margin-top: 40px;
    }

    .home-menu {
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .home-edit {
        background: linear-gradient(135deg, #757009, #cfc61d);
        color: white;
        text-align: center;
        padding: 10px 0px;
        border-radius: 15px;
        width: 200px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .home-edit:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.25);
        }

        .home-edit i {
            font-size: 1rem;
            margin-bottom: 5px;
            display: block;
        }

        .home-edit h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: bold;
        }

