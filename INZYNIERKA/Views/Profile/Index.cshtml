@model INZYNIERKA.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Profile Home Page";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <h1>@Model.UserName</h1>
        <p class="lead">@Model.PublicDescription</p>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-md-4 text-center">
            <img src="@Model.Avatar" alt="Avatar" class="img-fluid rounded-circle mb-3" />
        </div>
        <div class="col-md-8">
            <h4>Private Description:</h4>
            <p>@Model.PrivateDescription</p>

            <h5>Twoje tagi:</h5>
            <ul class="list-inline">
                @foreach (var tag in Model.Tags)
                {
                    <li class="list-inline-item badge bg-primary mx-1">@tag</li>
                }
            </ul>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-center gap-3">
        <a asp-controller="Profile" asp-action="EditProfile" class="btn btn-outline-primary">Edit profile</a>
        <a asp-controller="Profile" asp-action="SelectTags" class="btn btn-outline-secondary">Tags</a>
        <a asp-controller="Profile" asp-action="FriendList" class="btn btn-outline-success">Friends</a>
        <a asp-controller="Profile" asp-action="RequestList" class="btn btn-outline-warning">Requests</a>
    </div>
</div>
