@model INZYNIERKA.Services.ViewModels.NotificationListViewModel

@{
    ViewData["Title"] = "Notifications";
}

<div class="container py-4" style="max-width: 700px;">
    <h3 class="mb-4">Notifications</h3>

    @if (Model.Notifications.Any())
    {
        <ul class="list-group">
            @foreach (var notification in Model.Notifications)
            {
                <li class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center">
                    <div>
                        @if (notification.NotificationType == NotificationType.FriendRequest)
                        {
                            <span>@notification.SenderUserName Sended friend request</span>
                        }
                        else if (notification.NotificationType == NotificationType.Message)
                        {
                            <span>New Message from: <strong>@notification.SenderUserName</strong></span>
                        }
                        else if (notification.NotificationType == NotificationType.GroupMessage)
                        {
                            <span>New Message in group: <strong>@notification.GroupName</strong></span>
                        }
                        <br />
                        <small class="text-muted">@notification.CreationDate.ToString("g")</small>
                    </div>

                    <div class="menu">
                        @if (notification.NotificationType == NotificationType.FriendRequest)
                        {
                            <form asp-action="FriendRequestAccept" method="post" class="d-inline ms-3">
                                <input type="hidden" name="notificationId" value="@notification.Id" />
                                <input type="hidden" name="senderUserName" value="@notification.SenderUserName" />
                                <button type="submit" class="accept">Accept</button>
                            </form>
                        }
                        else if (notification.NotificationType == NotificationType.Message)
                        {
                            /*<form asp-controller="Chat" asp-action="Chat" method="post" class="d-inline ms-3">
                                <input type="hidden" name="friendId" value="@notification.SenderUserName" />     ///zmienić powiadomienia żeby wysyłały SENDER ID
                                <button type="submit" class="accept">Accept</button>
                            </form>*/
                        }

                        <form asp-action="DeleteNotification" method="post" class="ms-md-3 mt-2 mt-md-0">
                            <input type="hidden" name="notificationId" value="@notification.Id" />
                            <button type="submit" class="delete">Delete</button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No notifications</p>
    }
</div>

<style>

    .menu {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
    }

    .delete {
        background: linear-gradient(135deg, #8c144c, #d43780);
        color: white;
        text-align: center;
        padding: 10px 0px;
        border-radius: 15px;
        width: 100px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .delete:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.25);
        }

    .accept {
        background: linear-gradient(135deg, #1c7a15, #32b528);
        color: white;
        text-align: center;
        padding: 10px 0px;
        border-radius: 15px;
        width: 100px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .accept:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.25);
        }

</style>