@model INZYNIERKA.Services.ViewModels.ChatViewModel

@{
    ViewData["Title"] = "Chat";
}

<div class="container py-4">

        <div class="flex-grow-1" style="min-width: 300px;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>@Model.FriendName</h3>
                <a asp-controller="Profile" asp-action="ShowProfile" asp-route-userId="@Model.FriendId" class="show">
                    Show Profile
                </a>
            </div>

            <div id="chatWindow" class="border rounded p-3 mb-3" style="height: 300px; overflow-y: auto; background-color: #f9f9f9;">
                @foreach (var msg in Model.Messages)
                {
                    <div>
                        <strong>@msg.SenderName:</strong>
                        @if (msg.IsImage)
                        {
                            <br />
                            <img src="data:@msg.ImageType;base64,@msg.ImageDataBase64" style="max-width: 200px; border-radius: 8px; margin-top: 5px;" />
                        }
                        else
                        {
                            @msg.Content
                        }
                    </div>
                }
            </div>

            <div class="input-group">
                <input type="file" id="imageInput" accept="image/*" style="display:none;" />
                <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('imageInput').click()">🖼️</button>

                <input type="text" id="messageInput" class="form-control"
                       placeholder="Write a message..."
                       value="@(string.IsNullOrEmpty(Model?.UserMessage) ? "" : Model.UserMessage)" />
                <button id="sendButton" class="btn btn-primary bg">Send</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.GeminiAnswer))
        {
            <div class="mt-3 p-3 bg-light rounded border">
                <strong>Gemini:</strong> @Model.GeminiAnswer
            </div>
        }

        <div class="menu">
            <form method="post" asp-action="ResponseHelp">
                <input type="hidden" name="FriendId" value="@Model.FriendId" />
                <button type="submit" class="mybtn">Help with response</button>
            </form>

            <form id="CorrectForm" method="post" asp-action="CorrectMessage">
                <input type="hidden" name="FriendId" value="@Model.FriendId" />
                <input type="hidden" id="userMessageCorrect" name="UserMessage" value="" />
                <button type="submit" class="mybtn">Correct my message</button>
            </form>

            <form id="TranslateForm" method="post" asp-action="TranslateMessage">
                <input type="hidden" name="FriendId" value="@Model.FriendId" />
                <input type="hidden" id="userMessageTranslate" name="UserMessage" value="" />
                <button type="submit" class="mybtn">Translate</button>
            </form>
        </div>
    
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .withAutomaticReconnect()
            .build();

        async function start() {
            await connection.start();
        }

        start()

        const chatWindow = document.getElementById("chatWindow");

        let loadedMessagesCount = 30;
        let isLoadingOlder = false;
        let hasMoreMessages = true;

        chatWindow.addEventListener("scroll", async function() {
            if (chatWindow.scrollTop === 0 && !isLoadingOlder && hasMoreMessages) {
                isLoadingOlder = true;
                
                const previousScrollHeight = chatWindow.scrollHeight;

                try {
                    const response = await fetch(`/Chat/LoadOlderMessages?friendId=@Model.FriendId&skip=${loadedMessagesCount}`);
                    if (response.ok) {
                        const olderMessages = await response.json();

                        if (olderMessages.length > 0) {
                            loadedMessagesCount += olderMessages.length;
                            
                            let olderHtml = "";
                            olderMessages.forEach(msg => {
                                const senderName = msg.senderId === "@Model.CurrentUserId" ? "You" : "@Model.FriendName";
                                let contentHtml = msg.isImage ? `<br/><img src="data:${msg.contentType};base64,${msg.imageDataBase64}" style="max-width: 200px; border-radius: 8px; margin-top: 5px;" />` : msg.content;
                                    
                                olderHtml += `<div><strong>${senderName}:</strong> ${contentHtml}</div>`;
                            });

                            chatWindow.insertAdjacentHTML('afterbegin', olderHtml);

                            chatWindow.scrollTop = chatWindow.scrollHeight - previousScrollHeight;
                        }

                        if (olderMessages.length < 30) {
                            hasMoreMessages = false;
                        }
                    }
                } catch (err) {
                    console.error("Błąd przy ładowaniu starszych wiadomości", err);
                } finally {
                     isLoadingOlder = false;
                }
            }
        });

        function appendMessage(senderId, content, isHtml) {
            const currentFriendId = "@Model.FriendId";
            const currentUserId = "@Model.CurrentUserId";
            
            const chatWindow = document.getElementById("chatWindow");
            const div = document.createElement("div");
            const senderName = senderId === currentUserId ? "You" : "@Model.FriendName";
            
            if (isHtml) {
            div.innerHTML = `<strong>${senderName}:</strong> ${content}`;
            } else {
            const strong = document.createElement("strong");
            strong.textContent = senderName + ": ";
            div.appendChild(strong);
            const text = document.createTextNode(content);
            div.appendChild(text);
            }

            chatWindow.appendChild(div);
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }

        connection.on("ReceiveImage", function(senderId, receiverId, base64Data, contentType) {
            const imgHtml = `<br/><img src="data:${contentType};base64,${base64Data}" style="max-width: 200px; border-radius: 8px; margin-top: 5px;" />`;
            appendMessage(senderId, imgHtml, true);
        });

        connection.on("ReceiveMessage", function(senderId, receiverId, message) {
            appendMessage(senderId, message, false);
        });

        connection.on("ErrorNotification", function(errorMessage) {
            alert(errorMessage);
        });

        document.getElementById("sendButton").addEventListener("click", function () {
            const messageInput = document.getElementById("messageInput");
            const message = messageInput.value;

            if (!message.trim() === "");

            connection.invoke("SendMessage", "@Model.CurrentUserId", "@Model.FriendId", message)
                .catch(err => console.error(err.toString()));

            messageInput.value = "";
        });

        document.getElementById("imageInput").addEventListener("change", function() {
            const file = this.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onloadend = function() {
            const base64Data = reader.result.split(',')[1];
            const contentType = file.type;

            connection.invoke("SendImage", "@Model.CurrentUserId", "@Model.FriendId", base64Data, contentType)
            .catch(err => console.error(err.toString()));
            };
            reader.readAsDataURL(file);
            this.value = "";
        });

        connection.onclose(async () => {
                    console.log("Disconnected, reconnecting...");
            await start();
        });
    </script>

    <script>
        function bindMessageToForm(formId, hiddenInputId) {
            document.getElementById(formId).addEventListener("submit", function () {
                var message = document.getElementById("messageInput").value;
                document.getElementById(hiddenInputId).value = message;
            });
        }

        bindMessageToForm("CorrectForm", "userMessageCorrect");
        bindMessageToForm("TranslateForm", "userMessageTranslate");
    </script>

    <script>
        document.getElementById("messageInput").addEventListener("focus", function () {
            connection.invoke("ClearNotifications", "@Model.CurrentUserId", "@Model.FriendId")
                .catch(err => console.error(err.toString()));
        });
    </script>

    <style>
        .menu {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .mybtn {
            background: linear-gradient(135deg, #ae2eb8, #3b82f6);
            color: white;
            text-align: center;
            padding: 10px 0px;
            border-radius: 15px;
            width: 300px;
            text-decoration: none;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .mybtn:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 25px rgba(0,0,0,0.25);
            }

        .show {
            background: linear-gradient(135deg, #757009, #cfc61d);
            color: white;
            text-align: center;
            padding: 10px 0px;
            border-radius: 15px;
            width: 200px;
            text-decoration: none;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .show:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 25px rgba(0,0,0,0.25);
            }

        .bg {
            background: linear-gradient(135deg, #552459, #ae2eb8);
        }
    </style>
}