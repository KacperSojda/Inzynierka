@model INZYNIERKA.ViewModels.ChatViewModel

@{
    ViewData["Title"] = "Chat";
}

<div class="container py-4">
    <div class="d-flex flex-wrap gap-4">
        <!-- Lewa kolumna: rozmowa -->
        <div class="flex-grow-1" style="min-width: 300px; max-width: 600px;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>Rozmowa</h3>
                <form asp-controller="Profile" asp-action="ShowProfile" method="post" class="m-0">
                    <input type="hidden" name="userId" value="@Model.FriendId" />
                    <button type="submit" class="btn btn-outline-primary btn-sm">Pokaż Profil</button>
                </form>
            </div>

            <div id="chatWindow" class="border rounded p-3 mb-3" style="height: 300px; overflow-y: auto; background-color: #f9f9f9;">
                @foreach (var msg in Model.Messages)
                {
                    <div>
                        <strong>@(msg.SenderId == Model.CurrentUserId ? "Ty" : "Znajomy"):</strong> @msg.Content
                    </div>
                }
            </div>

            <div class="input-group">
                <input type="text" id="messageInput" class="form-control" placeholder="Napisz wiadomość..." />
                <button id="sendButton" class="btn btn-primary">Wyślij</button>
            </div>
        </div>

        <!-- Prawa kolumna: AI Gemini -->
        <div style="min-width: 300px; max-width: 400px;">
            <h3>Zapytaj AI Gemini</h3>

            <form method="post" asp-action="AskGemini" class="mb-3">
                <textarea name="GeminiQuestion" rows="4" class="form-control" placeholder="Twoje pytanie...">@Model.GeminiQuestion</textarea>
                <input type="hidden" name="FriendId" value="@Model.FriendId" />
                <input type="hidden" name="UserMessage" value="@Model.UserMessage" />
                <button type="submit" class="btn btn-secondary mt-2 w-100">Zapytaj</button>
            </form>

            <form method="post" asp-action="ResponseHelp">
                <input type="hidden" name="FriendId" value="@Model.FriendId" />
                <input type="hidden" name="UserMessage" value="@Model.UserMessage" />
                <button type="submit" class="btn btn-outline-secondary w-100">Pomoc w odpowiedzi</button>
            </form>

            @if (!string.IsNullOrEmpty(Model.GeminiAnswer))
            {
                <div class="mt-3 p-3 bg-light rounded border">
                    <strong>Gemini:</strong> @Model.GeminiAnswer
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .build();

        connection.on("ReceiveMessage", function (senderId, receiverId, message) {
            const currentFriendId = "@Model.FriendId";
            const currentUserId = "@Model.CurrentUserId";

            if ((senderId != currentFriendId || receiverId != currentUserId) &&
                (senderId != currentUserId || receiverId != currentFriendId)) return;

            const chatWindow = document.getElementById("chatWindow");
            const div = document.createElement("div");
            div.innerHTML = `<strong>${senderId === "@Model.CurrentUserId" ? "Ty" : "Znajomy"}:</strong> ${message}`;
            chatWindow.appendChild(div);
            chatWindow.scrollTop = chatWindow.scrollHeight;
        });

        document.getElementById("sendButton").addEventListener("click", function () {
            const message = document.getElementById("messageInput").value;
            if (!message.trim()) return;
            connection.invoke("SendMessage", "@Model.CurrentUserId", "@Model.FriendId", message)
                .catch(err => console.error(err.toString()));
            document.getElementById("messageInput").value = "";
        });
    </script>
}