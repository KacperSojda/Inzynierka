@model INZYNIERKA.Services.ViewModels.GroupChatViewModel

<div class="row mb-3">
    <div class="col">
        <p class="display-4">@Model.groupName</p>
    </div>
</div>

<div id="chatWindow" class="border rounded p-3 mb-3 bg-light" style="height:300px; overflow-y:auto;">
    @foreach (var msg in Model.messages)
    {
        <div>
            <strong>@(msg.SenderId == Model.currentUserID ? "You" : msg.SenderName):</strong>
            
            @if (msg.IsImage)
            {
                <br />
                <img src="data:@msg.ImageType;base64,@msg.ImageDataBase64" style="max-width: 200px; border-radius: 8px; margin-top: 5px;" />
            }
            else
            {
                @msg.Content
            }
        </div>
    }
</div>

<div class="input-group">
    <input type="file" id="groupImageInput" accept="image/*" style="display:none;" />
    <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('groupImageInput').click()">🖼️</button>
    <input type="text" id="messageInput" class="form-control"
           placeholder="Write a message..."
           value="@(string.IsNullOrEmpty(Model?.UserMessage) ? "" : Model.UserMessage)" />
    <button id="sendButton" class="btn btn-primary bg">Send</button>
</div>

@if (!string.IsNullOrEmpty(Model.GeminiAnswer))
{
    <div class="mt-3 p-3 bg-light rounded border">
        <strong>Gemini:</strong> @Model.GeminiAnswer
    </div>
}
<div class="menu">
    <form method="post" asp-action="GroupResponseHelp" asp-controller="Chat">
        <input type="hidden" name="groupId" value="@Model.groupID" />
        <button type="submit" class="mybtn">Help with response</button>
    </form>

    <form id="CorrectForm" method="post" asp-action="GroupCorrectMessage" asp-controller="Chat">
        <input type="hidden" name="groupId" value="@Model.groupID" />
        <input type="hidden" id="userMessageCorrect" name="UserMessage" value="" />
        <button type="submit" class="mybtn">Correct my message</button>
    </form>

    <form id="TranslateForm" method="post" asp-action="GroupTranslateMessage" asp-controller="Chat">
        <input type="hidden" name="groupId" value="@Model.groupID" />
        <input type="hidden" id="userMessageTranslate" name="UserMessage" value="" />
        <button type="submit" class="mybtn">Translate</button>
    </form>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/groupchathub")
            .withAutomaticReconnect()
            .build();

        const currentgroupID = "@Model.groupID";
        const currentUserId = "@Model.currentUserID";

        async function start() {
            await connection.start();
            await connection.invoke("JoinGroup", `group_${currentgroupID}`);
        }

        start();

        const chatWindow = document.getElementById("chatWindow");

        let loadedMessagesCount = 30;
        let isLoadingOlder = false;
        let hasMoreMessages = true;

        chatWindow.addEventListener("scroll", async function() {
            if (chatWindow.scrollTop === 0 && !isLoadingOlder && hasMoreMessages) {
                isLoadingOlder = true;
                const previousScrollHeight = chatWindow.scrollHeight;

                try {
                    const response = await fetch(`/Chat/LoadOlderGroupMessages?groupId=${currentgroupID}&skip=${loadedMessagesCount}`);
                    if (response.ok) {
                        const olderMessages = await response.json();

                        if (olderMessages.length > 0) {
                            loadedMessagesCount += olderMessages.length;
                            let olderHtml = "";

                            olderMessages.forEach(msg => {
                                const senderLabel = msg.senderId === currentUserId ? "You" : msg.senderName;
                                let contentHtml = msg.isImage ? `<br/><img src="data:${msg.imageType};base64,${msg.imageDataBase64}" style="max-width: 200px; border-radius: 8px; margin-top: 5px;" />` : msg.content;
                                    
                                olderHtml += `<div><strong>${senderLabel}:</strong> ${contentHtml}</div>`;
                            });

                            chatWindow.insertAdjacentHTML('afterbegin', olderHtml);
                            chatWindow.scrollTop = chatWindow.scrollHeight - previousScrollHeight;
                        }

                        if (olderMessages.length < 30) {
                            hasMoreMessages = false;
                        }
                    }
                } catch (err) {
                    console.error("Błąd przy ładowaniu starszych wiadomości", err);
                } finally {
                    isLoadingOlder = false;
                }
            }
        });

        function appendGroupMessage(senderId, content, isHtml) {
            const chatWindow = document.getElementById("chatWindow");
            const div = document.createElement("div");
            
            const senderLabel = senderId === currentUserId ? "You" : senderId;

            if (isHtml) {
                div.innerHTML = `<strong>${senderLabel}:</strong> ${content}`;
            } else {
                const strong = document.createElement("strong");
                strong.textContent = senderLabel + ": ";
                div.appendChild(strong);
                
                const text = document.createElement("span");
                text.textContent = content; // Zabezpieczenie przed XSS
                div.appendChild(text);
            }

            chatWindow.appendChild(div);
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }

        connection.on("ReceiveGroupMessage", function(groupId, senderId, message) {
            if (groupId != currentgroupID) return;
            appendGroupMessage(senderId, message, false);
        });

        connection.on("ReceiveGroupImage", function(groupId, senderId, base64Data, contentType) {
            if (groupId != currentgroupID) return;
            const imgHtml = `<br/><img src="data:${contentType};base64,${base64Data}" style="max-width: 200px; border-radius: 8px; margin-top: 5px;" />`;
            appendGroupMessage(senderId, imgHtml, true);
        });

        document.getElementById("sendButton").addEventListener("click", function () {
            const messageInput = document.getElementById("messageInput");
            const message = messageInput.value;

            if (!message.trim()) return

            connection.invoke("SendMessageToGroup", currentgroupID, currentUserId, message)
                .catch(err => console.error(err.toString()));
            
            messageInput.value = "";
        });

        document.getElementById("groupImageInput").addEventListener("change", function() {
            const file = this.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onloadend = function() {
                const base64Data = reader.result.split(',')[1];
                const contentType = file.type;

                connection.invoke("SendGroupImage", currentgroupID.toString(), currentUserId, base64Data, contentType)
                .catch(err => console.error("Upload error:", err.toString()));
            };
            reader.readAsDataURL(file);
            this.value = "";
        });

        connection.on("ErrorNotification", function(errorMessage) {
            alert(errorMessage);
        });
    </script>

    <script>
        function bindMessageToForm(formId, hiddenInputId) {
            document.getElementById(formId).addEventListener("submit", function () {
                var message = document.getElementById("messageInput").value;
                document.getElementById(hiddenInputId).value = message;
            });
        }

        bindMessageToForm("CorrectForm", "userMessageCorrect");
        bindMessageToForm("TranslateForm", "userMessageTranslate");
    </script>

    <style>
        .menu {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .mybtn {
            background: linear-gradient(135deg, #ae2eb8, #3b82f6);
            color: white;
            text-align: center;
            padding: 10px 0px;
            border-radius: 15px;
            width: 300px;
            text-decoration: none;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .mybtn:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 25px rgba(0,0,0,0.25);
            }

        .show {
            background: linear-gradient(135deg, #757009, #cfc61d);
            color: white;
            text-align: center;
            padding: 10px 0px;
            border-radius: 15px;
            width: 200px;
            text-decoration: none;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .show:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 25px rgba(0,0,0,0.25);
            }
    </style>
}