@model INZYNIERKA.Services.ViewModels.GroupViewModel

<div class="row">
    <div class="col">
        <p class="display-4">Your groups</p>
    </div>
</div>

@if (!Model.AdminGroups.Any() && !Model.Groups.Any())
{
    <h4>You don't belong to any group!</h4>
    <a asp-controller="Group" asp-action="ShowAvailableGroups" class="btn btn-primary">Search for groups</a>
}

@if (Model.AdminGroups.Any())
{
    <h3 class="mb-3">Admin</h3>
    <div class="d-flex flex-column gap-4 mb-5">
        @foreach (var group in Model.AdminGroups)
        {
            <div class="group-card border rounded p-3 bg-light shadow-sm">
                <div class="row align-items-center mb-2">
                    <div class="col-md-4">
                        <p class="display-6 mb-0">@group.Name</p>
                    </div>
                    <div class="col-md-8">
                        <div class="menu justify-content-md-end">
                            <form asp-action="LeaveGroup" method="post" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="leave">Leave</button>
                            </form>
                            <form asp-action="ShowGroupMembers" method="post" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="show">Show members</button>
                            </form>
                            <form asp-action="GroupChat" asp-controller="Chat" method="get" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="chat">Chat</button>
                            </form>
                            <form asp-action="EditGroup" asp-controller="Group" method="get" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="edit">Edit group</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col">
                        @if (group.Tags.Any())
                        {
                            <ul class="list-inline mb-2">
                                @foreach (var tag in group.Tags)
                                {
                                    <li class="list-inline-item badge custom-badge">@tag</li>
                                }
                            </ul>
                        }
                        <p class="lead mb-0">@group.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.Groups.Any())
{
    <h3 class="mb-3">Groups</h3>
    <div class="d-flex flex-column gap-4">
        @foreach (var group in Model.Groups)
        {
            <div class="group-card border rounded p-3 bg-light shadow-sm">
                <div class="row align-items-center mb-2">
                    <div class="col-md-4">
                        <p class="display-6 mb-0">@group.Name</p>
                    </div>
                    <div class="col-md-8">
                        <div class="menu justify-content-md-end">
                            <form asp-action="LeaveGroup" method="post" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="leave">Leave</button>
                            </form>
                            <form asp-action="ShowGroupMembers" method="post" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="show">Show members</button>
                            </form>
                            <form asp-action="GroupChat" asp-controller="Chat" method="get" class="m-0">
                                <input type="hidden" name="groupId" value="@group.GroupId" />
                                <button type="submit" class="chat">Chat</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col">
                        @if (group.Tags.Any())
                        {
                            <ul class="list-inline mb-2">
                                @foreach (var tag in group.Tags)
                                {
                                    <li class="list-inline-item badge custom-badge">@tag</li>
                                }
                            </ul>
                        }
                        <p class="lead mb-0">@group.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .menu {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    /* Guziki */
    .leave {
        background: linear-gradient(135deg, #8c144c, #d43780);
    }

    .show {
        background: linear-gradient(135deg, #1c7a15, #32b528);
    }

    .chat {
        background: linear-gradient(135deg, #1b3480, #4565c4);
    }

    .edit {
        background: linear-gradient(135deg, #757009, #cfc61d);
    }

    .leave, .show, .chat, .edit {
        color: white;
        text-align: center;
        padding: 6px 15px;
        border-radius: 15px;
        min-width: 120px;
        text-decoration: none;
        border: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .leave:hover, .show:hover, .chat:hover, .edit:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

    .custom-badge {
        background: linear-gradient(135deg, #552459, #ae2eb8);
        color: white;
        padding: 8px 15px;
        border-radius: 15px;
        font-weight: normal;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
</style>
