@model INZYNIERKA.ViewModels.UserViewModel

<h3>@Model.UserName</h3>
<p> @Model.PublicDescription</p>
<p>Tagi: @string.Join(", ", @Model.Tags)</p>

<form asp-action="NextUser" method="post" style="display:inline;">
    <button type="submit" class="btn btn-primary">Next →</button>
</form>

<form asp-action="SendFriendRequest" method="post" style="display:inline;">
    <input type="hidden" name="userId" value="@Model.Id" />
    <button type="submit" class="btn btn-secondary">Send a friend request</button>
</form>