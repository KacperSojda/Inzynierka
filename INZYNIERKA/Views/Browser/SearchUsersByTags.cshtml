@model SearchByTagsViewModel

<h2>Search users by tags</h2>

<form method="post">
    <div class="tags-container">
        @for (int i = 0; i < Model.AvailableTags.Count; i++)
        {
            <input type="hidden" asp-for="AvailableTags[i].TagId" />
            <input type="checkbox" asp-for="AvailableTags[i].IsSelected" id="tag-@i" class="tag-checkbox" />
            <label for="tag-@i" class="tag-block">
                @Model.AvailableTags[i].TagName
            </label>
        }
    </div>

    <div class="mt-3">
        <button type="submit" class="save">Search</button>
    </div>
</form>

<a asp-controller="Browser" asp-action="SearchWithAI" class="AIsearch" title="Search by AI" data-bs-toggle="tooltipp"><i class="bi bi-pencil-square"></i> Search with AI</a>

<style>

    .save, .AIsearch, .add-tag {
        display: inline-block;
        text-align: center;
        padding: 5px 0;
        border-radius: 15px;
        width: 150px;
        text-decoration: none;
        color: white;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .save {
        background: linear-gradient(135deg, #1c7a15, #32b528);
    }

    .AIsearch {
        background: linear-gradient(135deg, #1c7a15, #32b528);
    }

    .add-tag {
        background: linear-gradient(135deg, #757009, #cfc61d);
    }

        .save:hover, .add-tag:hover, .AIsearch:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.25);
        }

</style>


    