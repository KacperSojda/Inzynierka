@model SearchByTagsViewModel

<h2>Search users by tags</h2>

<form method="post">
    <div>
        @for (int i = 0; i < Model.AvailableTags.Count; i++)
        {
            <div class="form-check">
                <input type="checkbox" asp-for="AvailableTags[@i].IsSelected" class="form-check-input" />
                <input type="hidden" asp-for="AvailableTags[@i].TagId" />
                <label class="form-check-label">@Model.AvailableTags[i].TagName</label>
            </div>
        }
    </div>
    <button type="submit" class="btn btn-primary mt-2">Search</button>
</form>
    